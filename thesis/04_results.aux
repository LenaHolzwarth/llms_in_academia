\@writefile{toc}{\contentsline {subsection}{\numberline {4.5}Overview of other studies}{31}{subsection.4.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces LLM-use estimates for different countries and language regions for the abstract and main body of the paper. The highest estimate in each panel is marked in a gray box. The estimates for NES and NNES are based on all relevant countries in the dataset, not only those shown here. The estimates of individual countries were ordered by maximum.}}{32}{figure.caption.15}\protected@file@percent }
\newlabel{fig:countries_ind}{{14}{32}{LLM-use estimates for different countries and language regions for the abstract and main body of the paper. The highest estimate in each panel is marked in a gray box. The estimates for NES and NNES are based on all relevant countries in the dataset, not only those shown here. The estimates of individual countries were ordered by maximum}{figure.caption.15}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {15}{\ignorespaces LLM-use estimates of 2024 (x-axis) and 2025 (y-axis) for different countries and language regions, based on the body of the papers. Countries with a majority of NES are shown in blue, NNES countries in orange.}}{33}{figure.caption.16}\protected@file@percent }
\newlabel{fig:countries_all}{{15}{33}{LLM-use estimates of 2024 (x-axis) and 2025 (y-axis) for different countries and language regions, based on the body of the papers. Countries with a majority of NES are shown in blue, NNES countries in orange}{figure.caption.16}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces Estimates from different studies and surveys investigating LLM-use in academia. The results from this study are plotted as lines, focussing on estimates for the abstract and main body of the paper. Results from other estimation methods are plotted in a blue-green color scale with empty markers, survey results are plotted in a yellow-red color scale with colored-in markers. Each individual color corresponds to estimates from the same study (estimates from the same study can also be identified by their vertical alignment, as they were all recorded at the same time). Different marker styles identify different methodologies to derive estimates, or different ways of using LLMs reported in the surveys.}}{34}{figure.caption.17}\protected@file@percent }
\newlabel{fig:comparison_all}{{16}{34}{Estimates from different studies and surveys investigating LLM-use in academia. The results from this study are plotted as lines, focussing on estimates for the abstract and main body of the paper. Results from other estimation methods are plotted in a blue-green color scale with empty markers, survey results are plotted in a yellow-red color scale with colored-in markers. Each individual color corresponds to estimates from the same study (estimates from the same study can also be identified by their vertical alignment, as they were all recorded at the same time). Different marker styles identify different methodologies to derive estimates, or different ways of using LLMs reported in the surveys}{figure.caption.17}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {17}{\ignorespaces LLM-use estimates for different sections within a paper from different estimation methods. The results from this study are plotted as lines, focussing on estimates for the abstract, introduction and main body of the paper, as these are the only sections with specific estimates reported in the Literature. Results from other estimation methods are colored in accordance with the investigated section (note that this leads to some estimates from the same paper being colored differently, because estimates for different sections were reported. Estimates from the same study can be found by their vertical alignment). Different marker styles identify different methodologies to derive estimates.}}{35}{figure.caption.18}\protected@file@percent }
\newlabel{fig:comparison_secs}{{17}{35}{LLM-use estimates for different sections within a paper from different estimation methods. The results from this study are plotted as lines, focussing on estimates for the abstract, introduction and main body of the paper, as these are the only sections with specific estimates reported in the Literature. Results from other estimation methods are colored in accordance with the investigated section (note that this leads to some estimates from the same paper being colored differently, because estimates for different sections were reported. Estimates from the same study can be found by their vertical alignment). Different marker styles identify different methodologies to derive estimates}{figure.caption.18}{}}
