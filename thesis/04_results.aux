\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Cropped sections}{25}{subsection.4.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces LLM-use estimates for the full sections. The upper panel shows monthly frequencies corresponding to the word list selected by the optimal cutoff for each section. Observed frequencies $q$ (solid lines) diverge from predicted frequencies $\hat  {p}_{human}$ (dotted lines) after the release of ChatGPT (dashed vertical line). In the lower panel, the corresponding LLM-use estimate $\hat  {\beta }$ is depicted.}}{26}{figure.caption.9}\protected@file@percent }
\newlabel{fig:monthly_est}{{9}{26}{LLM-use estimates for the full sections. The upper panel shows monthly frequencies corresponding to the word list selected by the optimal cutoff for each section. Observed frequencies $q$ (solid lines) diverge from predicted frequencies $\hph $ (dotted lines) after the release of ChatGPT (dashed vertical line). In the lower panel, the corresponding LLM-use estimate $\hbet $ is depicted}{figure.caption.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces LLM-use estimates for sections cropped to 255 words. The upper panel shows monthly frequencies corresponding to the word list selected by the optimal cutoff for each section. Observed frequencies $q$ (solid lines) diverge from predicted frequencies $\hat  {p}_{human}$ (dotted lines) after the release of ChatGPT (dashed vertical line). In the lower panel, the corresponding LLM-use estimate $\hat  {\beta }$ is depicted.}}{27}{figure.caption.11}\protected@file@percent }
\newlabel{fig:monthly_est_crop255}{{10}{27}{LLM-use estimates for sections cropped to 255 words. The upper panel shows monthly frequencies corresponding to the word list selected by the optimal cutoff for each section. Observed frequencies $q$ (solid lines) diverge from predicted frequencies $\hph $ (dotted lines) after the release of ChatGPT (dashed vertical line). In the lower panel, the corresponding LLM-use estimate $\hbet $ is depicted}{figure.caption.11}{}}
