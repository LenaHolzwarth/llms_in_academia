\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Cropped sections}{28}{subsection.4.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces LLM-use estimates for the full sections. The upper panel shows monthly frequencies corresponding to the word list selected by the optimal cutoff for each section. Observed frequencies $q$ (solid lines) diverge from predicted frequencies $\hat  {p}_{human}$ (dotted lines) after the release of ChatGPT (dashed vertical line). In the lower panel, the corresponding LLM-use estimate $\hat  {\beta }$ is depicted.}}{29}{figure.caption.11}\protected@file@percent }
\newlabel{fig:monthly_est}{{11}{29}{LLM-use estimates for the full sections. The upper panel shows monthly frequencies corresponding to the word list selected by the optimal cutoff for each section. Observed frequencies $q$ (solid lines) diverge from predicted frequencies $\hph $ (dotted lines) after the release of ChatGPT (dashed vertical line). In the lower panel, the corresponding LLM-use estimate $\hbet $ is depicted}{figure.caption.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces LLM-use estimates for sections cropped to 255 words. The upper panel shows monthly frequencies corresponding to the word list selected by the optimal cutoff for each section. Observed frequencies $q$ (solid lines) diverge from predicted frequencies $\hat  {p}_{human}$ (dotted lines) after the release of ChatGPT (dashed vertical line). In the lower panel, the corresponding LLM-use estimate $\hat  {\beta }$ is depicted.}}{30}{figure.caption.13}\protected@file@percent }
\newlabel{fig:monthly_est_crop255}{{12}{30}{LLM-use estimates for sections cropped to 255 words. The upper panel shows monthly frequencies corresponding to the word list selected by the optimal cutoff for each section. Observed frequencies $q$ (solid lines) diverge from predicted frequencies $\hph $ (dotted lines) after the release of ChatGPT (dashed vertical line). In the lower panel, the corresponding LLM-use estimate $\hbet $ is depicted}{figure.caption.13}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces Yearly LLM-use estimates for different sections. Years are indicated by color. Panel \textbf  {a} shows the results for the full-length sections, panel \textbf  {b} those of sections cropped to 255 words.}}{31}{figure.caption.14}\protected@file@percent }
\newlabel{fig:est_per_section}{{13}{31}{Yearly LLM-use estimates for different sections. Years are indicated by color. Panel \textbf {a} shows the results for the full-length sections, panel \textbf {b} those of sections cropped to 255 words}{figure.caption.14}{}}
