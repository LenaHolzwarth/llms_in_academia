   keywords = {Computer science,Scientific community},
   month = {8},
   pages = {2599-2609},
   pmid = {40760036},
   publisher = {Nature Publishing Group},
   title = {Quantifying large language model usage in scientific papers},
   volume = {9},
   url = {https://www.nature.com/articles/s41562-025-02273-8},
   year = {2025}
}
