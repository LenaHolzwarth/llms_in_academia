\providecommand\hyper@newdestlabel[2]{}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Overview of countries and language regions, detailing the number of papers published in the time span from 2017 up to and including 2025. The language regions include papers from all relevant countries, not only those listed here.}}{67}{table.caption.31}\protected@file@percent }
\newlabel{tab:countires_counts}{{4}{67}{Overview of countries and language regions, detailing the number of papers published in the time span from 2017 up to and including 2025. The language regions include papers from all relevant countries, not only those listed here}{table.caption.31}{}}
\@writefile{toc}{\contentsline {section}{\numberline {E}Subgroup analysis}{67}{appendix.E}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {E.1}Countries and language regions}{67}{subsection.E.1}\protected@file@percent }
\newlabel{ap:countries}{{E.1}{67}{Countries and language regions}{subsection.E.1}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {E.2}Academic Discipline}{67}{subsection.E.2}\protected@file@percent }
\newlabel{ap:disciplines}{{E.2}{67}{Academic Discipline}{subsection.E.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {26}{\ignorespaces Observed and expected frequencies for the body of papers from different countries and language regions. The frequencies are computed with the wordlist created by the third-to-optimal cutoff, because higher cutoff values lead to unreliable results.}}{68}{figure.caption.32}\protected@file@percent }
\newlabel{fig:countries_freqs}{{26}{68}{Observed and expected frequencies for the body of papers from different countries and language regions. The frequencies are computed with the wordlist created by the third-to-optimal cutoff, because higher cutoff values lead to unreliable results}{figure.caption.32}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {27}{\ignorespaces Observed and expected frequencies for the body of papers from different countries and language regions, which were excluded from the analysis because they did not yield reliable estimates. The left panel shows frequencies based on the optimal word list, the right panel those based on the second-to-optimal word list. In both scenarios, there are many countries for which the observed frequency doesn't sufficiently differ from the expected frequency. Because our LLM-use estimate is based on the difference of observed and expected frequency, this leads to unreliable estimates.}}{69}{figure.caption.33}\protected@file@percent }
\newlabel{fig:countries_opt_subopt}{{27}{69}{Observed and expected frequencies for the body of papers from different countries and language regions, which were excluded from the analysis because they did not yield reliable estimates. The left panel shows frequencies based on the optimal word list, the right panel those based on the second-to-optimal word list. In both scenarios, there are many countries for which the observed frequency doesn't sufficiently differ from the expected frequency. Because our LLM-use estimate is based on the difference of observed and expected frequency, this leads to unreliable estimates}{figure.caption.33}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {28}{\ignorespaces Observed and expected frequencies for papers from different research disciplines. The frequencies are computed with the wordlist created by the third-to-optimal cutoff, because higher cutoff values lead to unreliable results. Because the number of papers per category is quite small, the error margins of the predictions can be quite large. Of note are the frequencies for papers from computation fields, where an outlier in 2022 leads to an expected frequency that is clearly too low. Because the LLM-use estimate is a metric based on the difference of expected and observed frequency, we can make no reliable estimate for this discipline.}}{70}{figure.caption.34}\protected@file@percent }
\newlabel{fig:disciplines_freqs}{{28}{70}{Observed and expected frequencies for papers from different research disciplines. The frequencies are computed with the wordlist created by the third-to-optimal cutoff, because higher cutoff values lead to unreliable results. Because the number of papers per category is quite small, the error margins of the predictions can be quite large. Of note are the frequencies for papers from computation fields, where an outlier in 2022 leads to an expected frequency that is clearly too low. Because the LLM-use estimate is a metric based on the difference of expected and observed frequency, we can make no reliable estimate for this discipline}{figure.caption.34}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {29}{\ignorespaces LLM-use estimates for different academic disciplines contributing to PMC for the abstract and main body of the paper. The highest estimate in each panel is marked in a gray box. The estimates are computed with the wordlist created by the third-to-optimal cutoff, because higher cutoff values lead to unreliable results.}}{71}{figure.caption.35}\protected@file@percent }
\newlabel{fig:disciplines_ind}{{29}{71}{LLM-use estimates for different academic disciplines contributing to PMC for the abstract and main body of the paper. The highest estimate in each panel is marked in a gray box. The estimates are computed with the wordlist created by the third-to-optimal cutoff, because higher cutoff values lead to unreliable results}{figure.caption.35}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {30}{\ignorespaces LLM-use estimates of 2024 (x-axis) and 2025 (y-axis) for different academic disciplines. Because the number of papers in each category is very small, some estimates have very high uncertainty, which is not visible in this plot.}}{72}{figure.caption.36}\protected@file@percent }
\newlabel{fig:disciplines_all}{{30}{72}{LLM-use estimates of 2024 (x-axis) and 2025 (y-axis) for different academic disciplines. Because the number of papers in each category is very small, some estimates have very high uncertainty, which is not visible in this plot}{figure.caption.36}{}}
