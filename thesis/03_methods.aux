\@writefile{toc}{\contentsline {section}{\numberline {3.2}Excess Frequency and LLM-use lower bound estimates}{20}{section.3.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3.2}{\ignorespaces Example of using excess frequency to determine lower bounds for LLM-use. Panel \textbf  {a} shows the frequency for the word ``these'' in PMC abstracts. The observed frequency $q$ (solid line) diverges strongly from the expected frequency $\hat  {p}_{human}$ based on the years before the release of ChatGPT. This difference corresponds to the frequency gap $Delta$ in panel \textbf  {b} (dashed line), which can be interpreted as a lower bound on LLM-use. A stronger lower bound $\beta _{lb}$ is also possible (solid line), which increases the estimated lower bound by over 0.1.}}{20}{figure.caption.5}\protected@file@percent }
\newlabel{fig:these}{{3.2}{20}{Example of using excess frequency to determine lower bounds for LLM-use. Panel \textbf {a} shows the frequency for the word ``these'' in PMC abstracts. The observed frequency $q$ (solid line) diverges strongly from the expected frequency $\hph $ based on the years before the release of ChatGPT. This difference corresponds to the frequency gap $Delta$ in panel \textbf {b} (dashed line), which can be interpreted as a lower bound on LLM-use. A stronger lower bound $\beta _{lb}$ is also possible (solid line), which increases the estimated lower bound by over 0.1}{figure.caption.5}{}}
\newlabel{eq:beta}{{3.2}{22}{Excess Frequency and LLM-use lower bound estimates}{equation.3.2.2}{}}
\newlabel{eq:delta}{{3.3}{22}{Excess Frequency and LLM-use lower bound estimates}{equation.3.2.3}{}}
\newlabel{eq:beta_hat}{{3.4}{23}{Excess Frequency and LLM-use lower bound estimates}{equation.3.2.4}{}}
\@writefile{toc}{\contentsline {section}{\numberline {3.3}Grouped word frequencies}{23}{section.3.3}\protected@file@percent }
\newlabel{subsec:wordlist}{{3.3}{23}{Grouped word frequencies}{section.3.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.3}{\ignorespaces Illustration of the frequency gap as a lower bound for LLM-use and why it (strongly) underestimates true LLM-use. In this example, we assume an underlying distribution that is shown in the top row. Humans are assumed to use a word in 60\% of texts, so $p_{human}=0.6$. This proportion is shown by the blue bar. We further assume that LLMs use a word in 80\% of texts ($p_{LLM}=0.8$), which is indicated by the green bar. LLM-use $\beta $ is assumed to be 0.5, meaning that half of the texts in the sample are LLM-assisted. When sampling from this distribution in the second row, we observe that in total, 70\% of texts use this word. This observation is the word frequency $q$ that we measure for PMC. In this example, we know that the 70\% of overall usage can be explained by a combination of humans and LLMs using this word. In particular, $p_{human}\cdot (1-\beta )= 60\% \cdot 0.5 = 30\%$ is explained by humans using the word, and $p_{LLM}\cdot \beta = 80\% \cdot 0.5 = 40\%$ is caused by LLMs using the word. However, when trying to estimate LLM-use, we only have access to $p_{human}$ (indirectly, via regression). Since we don't know $\beta $, the most conservative estimate is $\beta =0$, i.e. no texts are written with the help of LLMs. This means that we would expect $p_{human}\cdot (1-\beta )= 60\% \cdot 1 = 60\%$ of papers to include a term if all texts were written by humans, so the remaining $\Delta = q - p_{human}= 10\%$ of word occurrences must have been written by an LLM. Therefore the rate of LLM-use must at least be 10\%. This method of lower-bounding the LLM-use thus underestimates the true proportion of LLM-assisted text by 40 percentage points.}}{24}{figure.caption.6}\protected@file@percent }
\newlabel{fig:intution_estimates}{{3.3}{24}{Illustration of the frequency gap as a lower bound for LLM-use and why it (strongly) underestimates true LLM-use. In this example, we assume an underlying distribution that is shown in the top row. Humans are assumed to use a word in 60\% of texts, so $\ph =0.6$. This proportion is shown by the blue bar. We further assume that LLMs use a word in 80\% of texts ($\pl =0.8$), which is indicated by the green bar. LLM-use $\beta $ is assumed to be 0.5, meaning that half of the texts in the sample are LLM-assisted. When sampling from this distribution in the second row, we observe that in total, 70\% of texts use this word. This observation is the word frequency $q$ that we measure for PMC. In this example, we know that the 70\% of overall usage can be explained by a combination of humans and LLMs using this word. In particular, $\ph \cdot (1-\beta )= 60\% \cdot 0.5 = 30\%$ is explained by humans using the word, and $\pl \cdot \beta = 80\% \cdot 0.5 = 40\%$ is caused by LLMs using the word. However, when trying to estimate LLM-use, we only have access to $\ph $ (indirectly, via regression). Since we don't know $\beta $, the most conservative estimate is $\beta =0$, i.e. no texts are written with the help of LLMs. This means that we would expect $\ph \cdot (1-\beta )= 60\% \cdot 1 = 60\%$ of papers to include a term if all texts were written by humans, so the remaining $\Delta = q - \ph = 10\%$ of word occurrences must have been written by an LLM. Therefore the rate of LLM-use must at least be 10\%. This method of lower-bounding the LLM-use thus underestimates the true proportion of LLM-assisted text by 40 percentage points}{figure.caption.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.4}{\ignorespaces Examples of words with noticeable frequency changes in abstracts from PMC after the release of ChatGPT. The left column shows the word's observed frequency $q$, the right column shows the resulting lower bound estimates. While ``potential'' has a strong increase in frequency (panel \textbf  {a}), this only yields a lower bound estimate of below 10\% (panel \textbf  {b}). ``Delve'' has a very strong increase in frequency up to mid-2024, followed by a steep decrease (panel \textbf  {c}), which is mirrored in the lower bound estimates shown in panel \textbf  {d}.}}{25}{figure.caption.7}\protected@file@percent }
\newlabel{fig:potential_delve}{{3.4}{25}{Examples of words with noticeable frequency changes in abstracts from PMC after the release of ChatGPT. The left column shows the word's observed frequency $q$, the right column shows the resulting lower bound estimates. While ``potential'' has a strong increase in frequency (panel \textbf {a}), this only yields a lower bound estimate of below 10\% (panel \textbf {b}). ``Delve'' has a very strong increase in frequency up to mid-2024, followed by a steep decrease (panel \textbf {c}), which is mirrored in the lower bound estimates shown in panel \textbf {d}}{figure.caption.7}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.3.1}Excess words for 2024 PubMed}{26}{subsection.3.3.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3.5}{\ignorespaces Frequency ratios for all words in PubMed abstracts in 2018 (panel \textbf  {a}) and 2024 (panel \textbf  {b}). The frequency ratio is computed by dividing the frequency in the target year by the predicted frequency of the target year, based on linear predictions from two and three years prior. All words above the threshold (dashed line) are marked as excess words, i.e. words with notable change in frequency. Excess words are manually labeled as \emph  {content words} (blue dots) and \emph  {style words} (orange dots). In 2024, there are many more excess style words than in 2018. The Figure is taken from Kobak et al. \blx@tocontentsinit {0}\cite {Kobak2025}}}{26}{figure.caption.8}\protected@file@percent }
\newlabel{fig:excess_words_18_24}{{3.5}{26}{Frequency ratios for all words in PubMed abstracts in 2018 (panel \textbf {a}) and 2024 (panel \textbf {b}). The frequency ratio is computed by dividing the frequency in the target year by the predicted frequency of the target year, based on linear predictions from two and three years prior. All words above the threshold (dashed line) are marked as excess words, i.e. words with notable change in frequency. Excess words are manually labeled as \emph {content words} (blue dots) and \emph {style words} (orange dots). In 2024, there are many more excess style words than in 2018. The Figure is taken from Kobak et al. \cite {Kobak2025}}{figure.caption.8}{}}
