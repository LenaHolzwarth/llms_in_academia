\@writefile{toc}{\contentsline {subsection}{\numberline {3.4.2}Sanity check simulation}{32}{subsection.3.4.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3.7}{\ignorespaces Illustration of the sampling procedure for the creation of an artificial dataset to test the LLM-use estimate $\hat  {\beta }$ for varying levels of $\beta $. The dataset is modeled by a matrix with $n$ columns corresponding to documents and $m$ rows corresponding to excess words. The binary matrix entries tell us whether a word $w_i$ appears in document $d_j$. The matrix on the left, $M_{pre}$, corresponds to the pre-ChatGPT word frequencies. Here, the binary entries for word $w_i$ are drawn from a binomial distribution with probability $p_{human}(w_i)$. This probability is drawn from a gamma distribution. The matrix on the right, $M_{post}$, models post-ChatGPT word frequencies, meaning that some of the documents were written by humans (indicated in blue), while a fraction indicated by $\beta $ were written with the help of LLMs (green). For the blue part of the matrix, the matrix entries for word $w_i$ are drawn from the same binomial distribution as in $M_{pre}$, with probability $p_{human}(w_i)$. For the green part, the probability $p_{human}(w_i)$ is increased by $p_{human}(w_i)\delta _i$ with $\delta _i \sim U(0.5,5)$.}}{32}{figure.caption.10}\protected@file@percent }
\newlabel{fig:intution_simulation}{{3.7}{32}{Illustration of the sampling procedure for the creation of an artificial dataset to test the LLM-use estimate $\hbet $ for varying levels of $\beta $. The dataset is modeled by a matrix with $n$ columns corresponding to documents and $m$ rows corresponding to excess words. The binary matrix entries tell us whether a word $w_i$ appears in document $d_j$. The matrix on the left, $M_{pre}$, corresponds to the pre-ChatGPT word frequencies. Here, the binary entries for word $w_i$ are drawn from a binomial distribution with probability $\ph (w_i)$. This probability is drawn from a gamma distribution. The matrix on the right, $M_{post}$, models post-ChatGPT word frequencies, meaning that some of the documents were written by humans (indicated in blue), while a fraction indicated by $\beta $ were written with the help of LLMs (green). For the blue part of the matrix, the matrix entries for word $w_i$ are drawn from the same binomial distribution as in $M_{pre}$, with probability $\ph (w_i)$. For the green part, the probability $\ph (w_i)$ is increased by $\ph (w_i)\delta _i$ with $\delta _i \sim U(0.5,5)$}{figure.caption.10}{}}
