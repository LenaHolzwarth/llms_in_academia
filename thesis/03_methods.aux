\@writefile{lof}{\contentsline {figure}{\numberline {3.6}{\ignorespaces Behavior of different cutoff values and their corresponding excess word lists for PMC abstracts. Cutoffs are marked by color. Panel \textbf  {a} shows the word list frequency $q$ as solid lines and the expected frequency $\hat  {p}_{human}$ as dashed lines. Panel \textbf  {b} shows the lower bound estimates $\beta _{lb}$. For the highest cutoff values, both $q$ and $\hat  {p}_{human}$ are very close or equal to 1, leading to unreliable values with high fluctuation.}}{29}{figure.caption.9}\protected@file@percent }
\newlabel{fig:erratic}{{3.6}{29}{Behavior of different cutoff values and their corresponding excess word lists for PMC abstracts. Cutoffs are marked by color. Panel \textbf {a} shows the word list frequency $q$ as solid lines and the expected frequency $\hph $ as dashed lines. Panel \textbf {b} shows the lower bound estimates $\beta _{lb}$. For the highest cutoff values, both $q$ and $\hph $ are very close or equal to 1, leading to unreliable values with high fluctuation}{figure.caption.9}{}}
