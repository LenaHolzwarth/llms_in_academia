\newlabel{ap:opt}{{D}{79}{Word list optimization}{appendix.D}{}}
\@writefile{toc}{\contentsline {section}{\numberline {D.1}Full-length sections}{79}{section.D.1}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {D.2}Cropped sections}{79}{section.D.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {D.1}{\ignorespaces Detailed view of the optimization process on 2023 word frequency data (for full-length sections). Different cutoff values are plotted along the x-axis. Each panel, made up of two plots, corresponds to a different section. The left plot in each panel shows the expected frequency $\hat  {p}_{human}$ if all texts were written by humans and the observed frequency $q$. The right plot shows the LLM-use estimates derived from these frequencies. The cutoff yielding the highest LLM-use estimate is deemed optimal. Estimates for $\hat  {\beta }$ are only shown if the expected frequency $\hat  {p}_{human}$ is below $0.999$, and are only considered as candidates for optimality if their standard deviation is below $0.025$, otherwise they are displayed in gray.}}{80}{figure.caption.28}\protected@file@percent }
\newlabel{fig:2023_optimization}{{D.1}{80}{Detailed view of the optimization process on 2023 word frequency data (for full-length sections). Different cutoff values are plotted along the x-axis. Each panel, made up of two plots, corresponds to a different section. The left plot in each panel shows the expected frequency $\hph $ if all texts were written by humans and the observed frequency $q$. The right plot shows the LLM-use estimates derived from these frequencies. The cutoff yielding the highest LLM-use estimate is deemed optimal. Estimates for $\hbet $ are only shown if the expected frequency $\hph $ is below $0.999$, and are only considered as candidates for optimality if their standard deviation is below $0.025$, otherwise they are displayed in gray}{figure.caption.28}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {D.2}{\ignorespaces Detailed view of the optimization process on 2024 word frequency data (for full-length sections). Different cutoff values are plotted along the x-axis. Each panel, made up of two plots, corresponds to a different section. The left plot in each panel shows the expected frequency $\hat  {p}_{human}$ if all texts were written by humans and the observed frequency $q$. The right plot shows the LLM-use estimates derived from these frequencies. The cutoff yielding the highest LLM-use estimate is deemed optimal. Estimates for $\hat  {\beta }$ are only shown if the expected frequency $\hat  {p}_{human}$ is below $0.999$, and are only considered as candidates for optimality if their standard deviation is below $0.025$, otherwise they are displayed in gray.}}{81}{figure.caption.29}\protected@file@percent }
\newlabel{fig:2024_optimization}{{D.2}{81}{Detailed view of the optimization process on 2024 word frequency data (for full-length sections). Different cutoff values are plotted along the x-axis. Each panel, made up of two plots, corresponds to a different section. The left plot in each panel shows the expected frequency $\hph $ if all texts were written by humans and the observed frequency $q$. The right plot shows the LLM-use estimates derived from these frequencies. The cutoff yielding the highest LLM-use estimate is deemed optimal. Estimates for $\hbet $ are only shown if the expected frequency $\hph $ is below $0.999$, and are only considered as candidates for optimality if their standard deviation is below $0.025$, otherwise they are displayed in gray}{figure.caption.29}{}}
\newlabel{RF3}{82}
\@writefile{lot}{\contentsline {table}{\numberline {D.1}{\ignorespaces Yearly LLM-use estimates for all sections computed on full-length or cropped samples. The estimates for each year were computed with the optimal cutoff for this year. The table also states the length of the word list corresponding to each optimal cutoff. For the most part, the optimal cutoffs are relatively stable over different years, often only changing to the value directly before or after. }}{82}{table.caption.30}\protected@file@percent }
\newlabel{tab:llm-use-individual-cutoff}{{D.1}{82}{Yearly LLM-use estimates for all sections computed on full-length or cropped samples. The estimates for each year were computed with the optimal cutoff for this year. The table also states the length of the word list corresponding to each optimal cutoff. For the most part, the optimal cutoffs are relatively stable over different years, often only changing to the value directly before or after}{table.caption.30}{}}
